# Optional: add your OpenAI key for AI-powered diagnostics
# Without it, the app uses a smart built-in troubleshooting engine
OPENAI_API_KEY=

# Stripe — required to enable the $50/month Pro subscription checkout
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Optional: a pre-created recurring $50/month Price ID from the Stripe dashboard.
# If left blank, the checkout route creates the $50/month price inline.
STRIPE_PRICE_ID=

# Optional: your deployed app URL (defaults to the request origin / localhost)
NEXT_PUBLIC_BASE_URL=
